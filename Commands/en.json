        "time_unit": {
            "type": "regex",
            "patterns": {
                "1": "\\b(?:in|for|at)?\\s*seconds?\\b",
                "60": "\\b(?:in|for|at)?\\s*minutes?\\b",
                "3600": "\\b(?:in|for|at)?\\s*hours?\\b",
